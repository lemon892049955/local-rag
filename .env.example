# ===== LLM Provider 配置 =====
# 支持: kimi / deepseek / ollama
LLM_PROVIDER=kimi

# Kimi (Moonshot)
KIMI_API_KEY=your-kimi-api-key-here
KIMI_BASE_URL=https://api.moonshot.cn/v1
KIMI_MODEL=moonshot-v1-8k

# DeepSeek (备选)
DEEPSEEK_API_KEY=your-deepseek-api-key-here
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

# Ollama (本地, 无需 API Key)
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=qwen2.5:7b

# ===== Vision API 配置 (图片识别/表格提取) =====
# 可独立配置 Vision API（如 OpenAI GPT-4o），否则复用上方 LLM 配置
# 支持的模型: gpt-4o-mini, gpt-4o, claude-3-5-sonnet 等 OpenAI 兼容 API
# VISION_API_KEY=your-openai-api-key
# VISION_BASE_URL=https://api.openai.com/v1
# VISION_MODEL=gpt-4o-mini

# ===== Embedding 配置 =====
# 本地模型, 首次运行会自动下载 (~80MB)
EMBEDDING_MODEL=all-MiniLM-L6-v2

# ===== HTTP 代理配置 =====
# 用于访问外部 API（如热榜抓取、微信公众号等）
# 格式: http://host:port 或 socks5://host:port
# HTTP_PROXY=http://127.0.0.1:7890
# HTTPS_PROXY=http://127.0.0.1:7890

# ===== 服务配置 =====
HOST=0.0.0.0
PORT=8900

# ===== API 认证 =====
# 设置后，所有写入操作需要携带此 Token
# 留空则无需认证（仅限本地开发）
# API_TOKEN=your-secret-token-here

# ===== 企业微信配置 (Phase 2: 微信转发即入库) =====
# 在 https://work.weixin.qq.com 后台获取
WECOM_CORP_ID=your-corp-id              # 企业 ID (我的企业 → 企业信息)
WECOM_SECRET=your-app-secret            # 应用 Secret (应用管理 → 自建应用)
WECOM_AGENT_ID=1000002                  # 应用 AgentID
WECOM_TOKEN=your-callback-token         # 回调 Token (随机字符串，自己设)
WECOM_ENCODING_AES_KEY=your-aes-key     # 回调 EncodingAESKey (43位，自己设)

# ===== 日志级别 =====
# LOG_LEVEL=INFO
